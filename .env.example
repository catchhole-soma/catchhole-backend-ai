APP_NAME=CatchHole AI Backend
APP_VERSION=0.1.0
APP_ENV=local
DATABASE_URL=postgresql+psycopg://catchhole:catchhole@localhost:5432/catchhole
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=catchhole-dev
AWS_SQS_QUEUE_URL=
LLM_API_KEY=
LLM_MODEL=gpt-4.1-mini
OPENAI_RESPONSES_API_URL=https://api.openai.com/v1/responses
LLM_EXTRACTION_MAX_ATTEMPTS=3
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
EMBEDDING_VERSION=v1
OPENAI_EMBEDDINGS_API_URL=https://api.openai.com/v1/embeddings
SPRING_INTERNAL_API_BASE_URL=http://localhost:8080
SPRING_INTERNAL_API_KEY=local-development-internal-api-key
